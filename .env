# FastMCP Content Factory 环境配置

# =====================================================
# LLM API配置 (必需)
# =====================================================

# 云雾API配置 - 支持Qwen3模型
OPENAI_API_KEY=sk-6MT0V7g6AQz7ffGZFR9UhN0DtEleqY3lcmRaIe3MviYJIPP2
OPENAI_API_BASE=https://yunwu.ai/v1
OPENAI_MODEL=qwen3-235b-a22b-think

# Tavily搜索API配置 (用于Research Agent)
TAVILY_API_KEY=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

# =====================================================
# 数据存储配置 (可选)
# =====================================================

# Redis配置 (用于任务队列和缓存)
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# 数据库配置 (SQLite/PostgreSQL)
DATABASE_URL=sqlite:///./content_factory.db
# PostgreSQL示例:
# DATABASE_URL=postgresql://user:password@localhost:5432/content_factory

# =====================================================
# 系统配置
# =====================================================

# 日志级别
LOG_LEVEL=INFO

# 并发任务数
MAX_CONCURRENT_TASKS=3

# 任务超时时间 (秒)
TASK_TIMEOUT=1800

# 内容缓存时间 (秒)
CONTENT_CACHE_TTL=3600

# =====================================================
# Agent配置
# =====================================================

# Research Agent配置 - 使用Qwen3思考模型
RESEARCH_MODEL=qwen3-235b-a22b-think
RESEARCH_TEMPERATURE=0.1
RESEARCH_MAX_TOKENS=2000

# Writer Agent配置 - 使用Qwen3思考模型进行高质量中文写作
WRITER_MODEL=qwen3-235b-a22b-think
WRITER_TEMPERATURE=0.7
WRITER_MAX_TOKENS=4000

# Video Agent配置 - 使用Qwen3思考模型
VIDEO_MODEL=qwen3-235b-a22b-think
VIDEO_TEMPERATURE=0.6
VIDEO_MAX_TOKENS=3000

# Scorer Agent配置 - 使用Qwen3思考模型
SCORER_MODEL=qwen3-235b-a22b-think
SCORER_TEMPERATURE=0.2
SCORER_MAX_TOKENS=1500

# =====================================================
# 平台特定配置
# =====================================================

# 微信公众号
WECHAT_MIN_LENGTH=1500
WECHAT_MAX_LENGTH=3000

# 小红书
XIAOHONGSHU_MIN_LENGTH=300
XIAOHONGSHU_MAX_LENGTH=1000

# B站视频
BILIBILI_MIN_DURATION=180
BILIBILI_MAX_DURATION=600

# 抖音短视频
DOUYIN_MIN_DURATION=15
DOUYIN_MAX_DURATION=60

# =====================================================
# API服务配置
# =====================================================

# API服务器配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS配置
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# =====================================================
# 开发调试配置
# =====================================================

# 开发模式
DEBUG=false

# 启用详细日志
VERBOSE_LOGGING=false

# 启用性能监控
ENABLE_METRICS=false

# 模拟模式 (不调用真实API)
SIMULATION_MODE=false

# =====================================================
# 反审查系统配置
# =====================================================

# 主要模型配置 (使用Qwen3)
MODEL_NAME=qwen3-235b-a22b-think
YUNWU_API_KEY=sk-6MT0V7g6AQz7ffGZFR9UhN0DtEleqY3lcmRaIe3MviYJIPP2
YUNWU_API_BASE=https://yunwu.ai/v1

# 备用模型配置 (Claude for 反审查) - 通过Yunwu API
BACKUP_MODEL_NAME=claude-sonnet-4-20250514-thinking
CLAUDE_API_KEY=sk-6MT0V7g6AQz7ffGZFR9UhN0DtEleqY3lcmRaIe3MviYJIPP2
CLAUDE_API_BASE=https://yunwu.ai/v1

# OpenAI GPT-4备用配置
OPENAI_GPT4_API_KEY=
OPENAI_GPT4_MODEL=gpt-4-turbo

# 反审查系统开关
ANTI_CENSORSHIP_ENABLED=true
CENSORSHIP_DETECTION_SENSITIVITY=0.6
AUTO_SWITCH_THRESHOLD=0.7
MAX_RETRIES=2
LOG_MODEL_SWITCHES=true

# 检测配置
CHECK_CENSORSHIP_KEYWORDS=true
CHECK_TOPIC_DRIFT=true
CHECK_LENGTH_ANOMALY=true
CHECK_QUALITY_INDICATORS=true
MINIMUM_QUALITY_SCORE=0.3
